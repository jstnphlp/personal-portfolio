{
 "$schema": "https://app.kilo.ai/config.json",
 "instructions": [
  "AGENTS.md",
  "SKILLS.md"
 ],
  "mcp": {
   "chrome-devtools": {
    "type": "local",
    "command": [
     "npx",
     "-y",
     "chrome-devtools-mcp",
     "--autoConnect"
    ],
    "enabled": true
   },
   "playwright": {
    "type": "local",
    "command": [
     "npx",
     "-y",
     "@playwright/mcp"
    ],
    "enabled": true,
    "timeout": 30000
   }
  }
}
